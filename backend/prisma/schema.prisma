generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid())
  name                String?
  email               String   @unique
  phone               String?
  language            String   @default("en")
  accessibility_needs String?
  onboarding_complete Boolean  @default(false)
  password            String
  created_at          DateTime @default(now())
  trips               Trip[]
  preferences         UserPreferences?
  trip_reviews        TripReview[]
}

model Trip {
  id           Int          @id @default(autoincrement())
  user_id      String
  destination  String
  start_date   DateTime?
  end_date     DateTime?
  booking_id   String?
  status       String       @default("upcoming") // upcoming, ongoing, completed, cancelled
  created_at   DateTime     @default(now())

  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  chat_log     ChatLog?
  reviews      TripReview[]
  travel_readiness Json?
  ai_itinerary Json?
  
  
  hotelBooking  HotelBooking?
}


model ChatLog {
  id         Int      @id @default(autoincrement())
  trip_id    Int      @unique
  messages   Json     @default("[]")
  updated_at DateTime @default(now())
  trip       Trip     @relation(fields: [trip_id], references: [id], onDelete: Cascade)
}

model Destination {
  id                  Int      @id @default(autoincrement())
  name                String   @unique
  vr_assets           Json     @default("[]")
  local_tips          Json     @default("[]")
  emergency_contacts  Json     @default("{}")
  highlights          Json     @default("[]")
  updated_at          DateTime @default(now())
}

model UserPreferences {
  id                  Int      @id @default(autoincrement())
  user_id             String   @unique
  travel_style        String   @default("balanced") 
  food_preference     String   @default("all") 
  pace                String   @default("moderate") 
  interests           Json     @default("[]") 
  budget_level        String   @default("moderate") 
  onboarding_complete Boolean  @default(false)
  updated_at          DateTime @default(now())
  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Alert {
  id          Int      @id @default(autoincrement())
  trip_id     Int
  type        String   // weather, flight, safety, reminder
  title       String
  message     String   @db.Text
  priority    String   @default("medium") // low, medium, high, critical
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())
}

model TripMemory {
  id          Int      @id @default(autoincrement())
  trip_id     Int
  type        String   // place_visited, photo, note, highlight
  title       String
  description String?  @db.Text
  data        Json     @default("{}")
  created_at  DateTime @default(now())
}

model TripFeedback {
  id              Int      @id @default(autoincrement())
  trip_id         Int      @unique
  rating          Int      // 1-5
  highlights      Json     @default("[]")
  improvements    String?  @db.Text
  would_recommend Boolean  @default(true)
  created_at      DateTime @default(now())
}

model TripReview {
  id         Int      @id @default(autoincrement())
  trip_id    Int
  user_id    String
  rating     Int?     // 1-5, optional
  title      String?
  comment    String?  @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  trip       Trip     @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}


model HotelBooking {
  id           Int      @id @default(autoincrement())
  trip_id      Int      @unique
  name         String
  area         String?
  checkIn      DateTime
  checkOut     DateTime
  bookingRef   String?
  raw_response Json?

  vr_assets    Json?    

  trip         Trip     @relation(fields: [trip_id], references: [id])
}

model AICache {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  response   Json
  created_at DateTime @default(now())
}

model Hotel {
  id           Int      @id @default(autoincrement())
  name         String
  area         String
  destination  String
  priceRange   String?
  rating       Float?
  vr_assets    Json?
  created_at   DateTime @default(now())
}

