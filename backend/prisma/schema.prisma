generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid())
  name                String?
  email               String   @unique
  phone               String?
  language            String   @default("en")
  accessibility_needs String?
  password            String
  created_at          DateTime @default(now())
  trips               Trip[]
  preferences         UserPreferences?
}

model Trip {
  id           Int          @id @default(autoincrement())
  user_id      String
  destination  String
  start_date   DateTime?
  end_date     DateTime?
  booking_id   String?
  status       String       @default("active")
  created_at   DateTime     @default(now())
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  itinerary    Itinerary?
  chat_log     ChatLog?
}

model Itinerary {
  id            Int      @id @default(autoincrement())
  trip_id       Int      @unique
  plan          Json
  generated_at  DateTime @default(now())
  trip          Trip     @relation(fields: [trip_id], references: [id], onDelete: Cascade)
}

model ChatLog {
  id         Int      @id @default(autoincrement())
  trip_id    Int      @unique
  messages   Json     @default("[]")
  updated_at DateTime @default(now())
  trip       Trip     @relation(fields: [trip_id], references: [id], onDelete: Cascade)
}

model Destination {
  id                  Int      @id @default(autoincrement())
  name                String   @unique
  vr_assets           Json     @default("[]")
  local_tips          Json     @default("[]")
  emergency_contacts  Json     @default("{}")
  highlights          Json     @default("[]")
  updated_at          DateTime @default(now())
}

model UserPreferences {
  id                  Int      @id @default(autoincrement())
  user_id             String   @unique
  travel_style        String   @default("balanced") // relaxed, balanced, packed
  food_preference     String   @default("all") // veg, non-veg, vegan, all
  pace                String   @default("moderate") // slow, moderate, fast
  interests           Json     @default("[]") // array of interests
  budget_level        String   @default("moderate") // budget, moderate, luxury
  onboarding_complete Boolean  @default(false)
  updated_at          DateTime @default(now())
  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Alert {
  id          Int      @id @default(autoincrement())
  trip_id     Int
  type        String   // weather, flight, safety, reminder
  title       String
  message     String   @db.Text
  priority    String   @default("medium") // low, medium, high, critical
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())
}

model TripMemory {
  id          Int      @id @default(autoincrement())
  trip_id     Int
  type        String   // place_visited, photo, note, highlight
  title       String
  description String?  @db.Text
  data        Json     @default("{}")
  created_at  DateTime @default(now())
}

model TripFeedback {
  id              Int      @id @default(autoincrement())
  trip_id         Int      @unique
  rating          Int      // 1-5
  highlights      Json     @default("[]")
  improvements    String?  @db.Text
  would_recommend Boolean  @default(true)
  created_at      DateTime @default(now())
}